# ── Neon Postgres (adviso_106 database in the shared upwork-demos project) ────
# Runtime: the LIMITED role adviso_app_rls on the POOLED endpoint (the -pooler
# host). It is NOT the table owner, so RLS applies to it. postgres.js keeps
# { prepare: false } (PgBouncer transaction mode). Both URLs need ?sslmode=require.
APP_DATABASE_URL=postgresql://adviso_app_rls:PASSWORD@ep-xxx-pooler.<region>.aws.neon.tech/adviso_106?sslmode=require

# Migrations + seed: role neondb_owner on the DIRECT endpoint (no -pooler). Owner
# bypasses RLS by design (the service_role analogue). Session connection for DDL.
ADMIN_DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-xxx.<region>.aws.neon.tech/adviso_106?sslmode=require

# ── BYOK cookie encryption ────────────────────────────────────────────────────
# 32-byte base64 key used to AES-256-GCM encrypt the visitor's OpenAI key cookie.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BYOK_COOKIE_SECRET=replace-with-32-byte-base64-secret

# ── Embeddings ────────────────────────────────────────────────────────────────
# "deterministic" (default — no OpenAI needed, demo works keyless) or "openai".
EMBEDDINGS_PROVIDER=deterministic
# Only read by the seed route when EMBEDDINGS_PROVIDER=openai. Runtime chat/explanations
# always use the visitor's BYOK key, never this.
OPENAI_API_KEY=

# Default chat model used by the LangChain agent (paid by the visitor's BYOK key).
OPENAI_CHAT_MODEL=gpt-4o-mini
